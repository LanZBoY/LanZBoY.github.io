---
import Layout from '../layouts/Layout.astro';
import { profile, socials, experiences, skills, projects, awards } from '../data/site';

const icons: Record<string, string> = {
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  github: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>',
  linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
};
---

<Layout>
  <!-- 導覽列 -->
  <nav class="nav">
    <div class="container">
      <a href="#" class="logo">{profile.name}<span>.dev</span></a>
      <div class="links">
        <a href="#about">關於</a>
        <a href="#experience">經歷</a>
        <a href="#projects">作品</a>
        <a href="#awards">殊榮</a>
        <a href="/notes/">筆記</a>
        <a href="#contact">聯絡</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <header class="hero">
    <div class="container">
      {profile.avatar && <img class="avatar" src={profile.avatar} alt={profile.name} />}
      <p class="greeting">// hello world</p>
      <h1>{profile.name}</h1>
      <p class="title">{profile.title}</p>
      <p class="tagline">{profile.tagline}</p>
      <div class="socials">
        {socials.map((s) => (
          <a class="social-btn" href={s.href} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon] ?? ''} />
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </header>

  <!-- 關於我 -->
  <section id="about" class="about">
    <div class="container">
      <h2 class="section-title">關於我</h2>
      <p class="section-subtitle">About me</p>
      {profile.about.map((para) => <p>{para}</p>)}
      <div class="skill-groups">
        {skills.map((group) => (
          <div class="skill-group">
            <h3 class="skill-group-title">{group.category}</h3>
            <div class="skills">
              {group.items.map((skill) => <span class="skill-tag">{skill}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 經歷 -->
  <section id="experience">
    <div class="container">
      <h2 class="section-title">經歷</h2>
      <p class="section-subtitle">Experience</p>
      <div class="timeline">
        {experiences.map((exp) => (
          <div class="timeline-item">
            <p class="period">{exp.period}</p>
            <p class="role">{exp.role}</p>
            <p class="company">{exp.company}</p>
            <p class="desc">{exp.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 作品集 -->
  <section id="projects">
    <div class="container">
      <h2 class="section-title">作品集</h2>
      <p class="section-subtitle">Selected work</p>
      <div class="projects-grid">
        {projects.map((p) => (
          <article class="project-card">
            <h3>{p.title}</h3>
            <p class="desc">{p.description}</p>
            <div class="tags">{p.tags.map((t) => <span>{t}</span>)}</div>
            <div class="card-links">
              {p.link && <a href={p.link} target="_blank" rel="noopener">前往網站 ↗</a>}
              {p.repo && <a href={p.repo} target="_blank" rel="noopener">原始碼 ↗</a>}
              {p.video && <a href={p.video} target="_blank" rel="noopener">Demo 影片 ↗</a>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 競賽殊榮 -->
  <section id="awards">
    <div class="container">
      <h2 class="section-title">競賽殊榮</h2>
      <p class="section-subtitle">Honors &amp; Awards</p>
      <div class="awards-list">
        {awards.map((a) => (
          <article class="award-card">
            <span class="award-period">{a.period}</span>
            <div>
              <h3>{a.title}</h3>
              <p class="award-topic">題目：{a.topic}</p>
              <p class="award-desc">{a.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 聯絡 -->
  <section id="contact" style="text-align:center;">
    <div class="container">
      <h2 class="section-title">聯絡我</h2>
      <p class="section-subtitle">有任何合作或想聊聊，歡迎來信！</p>
      <div class="socials">
        {socials.map((s) => (
          <a class="social-btn" href={s.href} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon] ?? ''} />
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      © 2026 {profile.name}. Built with Astro · 部署於 GitHub Pages
    </div>
  </footer>
</Layout>
